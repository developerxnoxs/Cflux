# Test: Control flow edge cases
print("=== Control flow ===")

# Break in while
i = 0
while true:
    if i >= 5:
        break
    i = i + 1
print(i)  # 5

# Continue in for
total = 0
for x in range(10):
    if x % 2 == 0:
        continue
    total = total + x
print(total)  # 1+3+5+7+9 = 25

# Nested break
found = false
for i in range(5):
    for j in range(5):
        if i == 2 and j == 3:
            found = true
            break
    if found:
        break
print(found)  # true
print(i)      # 2
print(j)      # 3

# Return in middle of loop
func find_first(lst, val):
    for x in lst:
        if x == val:
            return true
    return false

print(find_first([1,2,3,4,5], 3))
print(find_first([1,2,3,4,5], 9))
