# Test 1: Basic match on int
let x = 2
match x:
    case 1:
        print("one")
    case 2:
        print("two")
    case 3:
        print("three")
    case _:
        print("other")

# Test 2: Match on string
let s = "hello"
match s:
    case "hi":
        print("hi case")
    case "hello":
        print("hello case")
    case _:
        print("default")

# Test 3: Match on bool
let b = true
match b:
    case true:
        print("is true")
    case false:
        print("is false")

# Test 4: Match with multiple statements in case
let n = 5
match n:
    case 5:
        let msg = "five"
        print(msg)
    case _:
        print("not five")

# Test 5: Nested match
let a = 1
let bb = 2
match a:
    case 1:
        match bb:
            case 2:
                print("a=1, b=2")
            case _:
                print("a=1, b!=2")
    case _:
        print("a!=1")

# Test 6: Match on null
let v = null
match v:
    case null:
        print("is null")
    case _:
        print("not null")

# Test 7: Match in a function
func describe(val):
    match val:
        case 0:
            return "zero"
        case 1:
            return "one"
        case _:
            return "many"

print(describe(0))
print(describe(1))
print(describe(99))
