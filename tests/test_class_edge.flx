# Test: Class edge cases
print("=== Class edge cases ===")

class Base:
    func __init__(x):
        self.x = x

    func get_x():
        return self.x

class Child(Base):
    func __init__(x, y):
        self.x = x
        self.y = y

    func get_sum():
        return self.x + self.y

c = Child(3, 4)
print(c.get_x())    # 3
print(c.get_sum())  # 7

# Access undefined attribute — harus error, bukan crash
print("Undefined attr:")
try:
    print(c.z)
catch e:
    print("[PASS] atribut tidak ada tertangkap: " + str(e))

print("class_edge: OK")
