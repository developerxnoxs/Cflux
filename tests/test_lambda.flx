# test_lambda.flx — regression tests for lambda expressions

# --- Expression-body lambda ---
let square  = |x| => x * x
let add     = |a, b| => a + b
let negate  = |x| => -x
let identity = |x| => x

print(square(5))         # 25
print(add(3, 4))         # 7
print(negate(10))        # -10
print(identity("hi"))    # hi

# --- Lambda with no parameters ---
let greet = || => "Hello!"
print(greet())           # Hello!

# --- Block-body lambda ---
let describe = |n| =>:
    if n > 0:
        return "positive"
    elif n < 0:
        return "negative"
    else:
        return "zero"

print(describe(5))       # positive
print(describe(-3))      # negative
print(describe(0))       # zero

# --- Higher-order function with lambda ---
func apply(f, val):
    return f(val)

print(apply(square, 6))     # 36
print(apply(negate, 7))     # -7

# --- Lambda capturing outer variable (closure) ---
func make_adder(n):
    return |x| => x + n

let add5 = make_adder(5)
let add10 = make_adder(10)
print(add5(3))              # 8
print(add10(3))             # 13

# --- Lambda with type annotation on params (annotation ignored) ---
let typed_add = |a: int, b: int| => a + b
print(typed_add(2, 3))      # 5

print("lambda: OK")
