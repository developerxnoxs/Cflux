# Test 1: Basic struct declaration and construction (bare fields)
struct Point:
    x
    y

let p = Point(1, 2)
print(p.x)
print(p.y)

# Test 2: Struct with default field access
struct Person:
    name
    age

let alice = Person("Alice", 30)
print(alice.name)
print(alice.age)

# Test 3: Struct field mutation
struct Counter:
    value

let c = Counter(0)
c.value = c.value + 1
print(c.value)

# Test 4: Nested struct
struct Rect:
    origin
    width
    height

let r = Rect(Point(0, 0), 10, 20)
print(r.width)
print(r.height)
print(r.origin.x)
print(r.origin.y)

# Test 5: Struct in a function
func make_point(x, y):
    return Point(x, y)

let q = make_point(5, 7)
print(q.x)
print(q.y)

# Test 6: Struct type check
print(type(p))
