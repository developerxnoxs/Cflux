# Test: List edge cases
print("=== List edge cases ===")

# Empty list
lst = []
print(len(lst))

# Append and access
lst.append(1)
lst.append(2)
lst.append(3)
print(lst[0])
print(lst[2])

# Negative indexing
print(lst[-1])
print(lst[-2])

# Out of bounds — harus error, bukan crash
print("Out of bounds test:")
try:
    print(lst[10])
catch e:
    print("[PASS] out of bounds tertangkap: " + str(e))

print("list_edge: OK")
