# ws_generic_echo_server.flx
# Echo server generik — port diambil dari sys.argv[2]
# Penggunaan: ./build_make/flux tests/ws_generic_echo_server.flx -- <PORT>
# Menerima SATU koneksi, echo semua pesan hingga client close/timeout, lalu keluar.
import ws
import sys

port = int(sys.argv[2])
srv = ws.listen("127.0.0.1", port)
conn = ws.accept(srv, 10)
if conn != null:
    msg = ws.recv(conn, 5)
    while msg != null:
        if msg["type"] == "text":
            ws.send(conn, "ECHO:" + msg["data"])
        msg = ws.recv(conn, 5)
    ws.close(conn)
ws.close_server(srv)
