# Fibonacci - rekursi dan loop

func fib_recursive(n):
    if n <= 1:
        return n
    return fib_recursive(n - 1) + fib_recursive(n - 2)

func fib_iterative(n):
    if n <= 1:
        return n
    a = 0
    b = 1
    i = 2
    while i <= n:
        c = a + b
        a = b
        b = c
        i = i + 1
    return b

print("Fibonacci (rekursi):")
for i in range(10):
    print(fib_recursive(i))

print("Fibonacci (iteratif):")
for i in range(15):
    print(fib_iterative(i))
