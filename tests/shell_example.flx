import shell

# --- shell.exec(cmd) ---
# Menjalankan perintah via shell, output langsung ke terminal.
# Mengembalikan exit code (int).
print("=== shell.exec ===")
code = shell.exec("echo Halo dari shell!")
print("exit code:", code)

# --- shell.capture(cmd) ---
# Menjalankan perintah dan menangkap stdout + stderr.
# Mengembalikan dict: {stdout, stderr, code}
print("\n=== shell.capture ===")
result = shell.capture("ls -1 examples/")
print("stdout:", result["stdout"])
print("stderr:", result["stderr"])
print("code  :", result["code"])

# Contoh dengan perintah yang gagal
result2 = shell.capture("ls /direktori_tidak_ada")
print("\nPerintah gagal — code:", result2["code"])
print("stderr:", result2["stderr"])

# --- shell.spawn(cmd, args) ---
# Menjalankan program dengan daftar argumen eksplisit (tanpa shell).
# Lebih aman dari injeksi perintah.
print("\n=== shell.spawn ===")
r = shell.spawn("echo", ["Halo", "dari", "spawn!"])
print("stdout:", r["stdout"])
print("code  :", r["code"])

# --- shell.pipe(cmd, args, input) ---
# Menjalankan program dengan argumen eksplisit DAN mengirimkan string ke stdin-nya.
# Berguna untuk memproses teks atau mem-pipe output satu perintah ke perintah lain.
print("\n=== shell.pipe ===")

# Filter baris yang mengandung ".flx"
daftar_file = shell.capture("ls examples/")
hanya_flx = shell.pipe("grep", [".flx"], daftar_file["stdout"])
print("File .flx di examples/:")
print(hanya_flx["stdout"])

# Hitung kata dalam sebuah kalimat
r2 = shell.pipe("wc", ["-w"], "Flux adalah bahasa pemrograman buatan sendiri")
print("Jumlah kata:", r2["stdout"])

# Ubah teks ke huruf kapital
r3 = shell.pipe("tr", ["a-z", "A-Z"], "flux programming language")
print("Kapital:", r3["stdout"])

# Chain multi-langkah: list file → filter → hitung
semua = shell.capture("ls -1 examples/")
hanya_flx2 = shell.pipe("grep", ["\\.flx$"], semua["stdout"])
jumlah = shell.pipe("wc", ["-l"], hanya_flx2["stdout"])
print("Jumlah file .flx:", jumlah["stdout"])
