# Test Python-style callable workers exposed by `import thread`.

import thread

func square(x):
    return x * x

func make_pair(left, right):
    return [left, right]

executor = thread.ThreadPoolExecutor(2)
first = executor.submit(square, 7)
second = executor.submit(square, 9)
pair = executor.submit(make_pair, "left", "right")

assert first.result() == 49
assert second.result() == 81
result = pair.result()
assert result[0] == "left"
assert result[1] == "right"
assert first.exception() == null

executor.shutdown()
print("thread.ThreadPoolExecutor callable workers OK")