# Bug Hunt: Async / Coroutines
print("=== ASYNC ===")

# Basic async/await
async func fetch_data():
    return 42

async func main():
    val = await fetch_data()
    print(val)   # 42
    return val

result = main()
# If coroutines need explicit stepping:
# while not result.done:
#     result.step()
print("async basic done")

# Async with computation
async func slow_add(a, b):
    return a + b

async func compute():
    x = await slow_add(3, 4)
    y = await slow_add(x, 10)
    return y

r = compute()
print("async compute done")

# Generator-like coroutine (if yield is supported)
# async func counter():
#     i = 0
#     while true:
#         yield i
#         i = i + 1

# Multiple awaits in sequence
async func step1():
    return "step1"

async func step2(s):
    return s + "+step2"

async func pipeline():
    s = await step1()
    result = await step2(s)
    print(result)   # step1+step2

pipeline()

print("ASYNC TESTS DONE")
