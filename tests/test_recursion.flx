# Test: Deep recursion / stack overflow
print("=== Recursion ===")

func countdown(n):
    if n <= 0:
        return 0
    return countdown(n - 1)

print(countdown(1000))
print(countdown(5000))

# Mutual recursion
func is_even(n):
    if n == 0:
        return true
    return is_odd(n - 1)

func is_odd(n):
    if n == 0:
        return false
    return is_even(n - 1)

print(is_even(10))
print(is_odd(7))
