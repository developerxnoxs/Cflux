# tests/test_async.flx — Test suite async/await Flux
#
# Mencakup seluruh fitur async:
#   1. await langsung (tanpa spawn) pada user-defined async func
#   2. Rantai await: async memanggil async
#   3. spawn + await handle — concurrency eksplisit
#   4. Auto-spawn: memanggil async func tanpa await → handle coroutine
#   5. yield — cooperative multitasking tanpa I/O
#   6. aio.sleep — non-blocking timer, urutan selesai sesuai delay
#   7. aio.read_file + aio.write_file — I/O file non-blocking
#   8. aio.gather([...]) — fan-out bersamaan, hasil urut sesuai input
#   9. aio.create_task(coro) — eksplisit task creation
#  10. Fan-out / fan-in manual: spawn banyak, await satu per satu

import aio

# ── Utilitas laporan ──────────────────────────────────────────────────────────
let hasil = [0, 0]   # [lulus, gagal]

func lulus(nama):
    print(f"  [LULUS] {nama}")
    hasil[0] = hasil[0] + 1

func gagal(nama, pesan):
    print(f"  [GAGAL] {nama}: {pesan}")
    hasil[1] = hasil[1] + 1

print("=== Flux Async Test Suite ===")

# ─────────────────────────────────────────────────────────────────────────────
# 1. await langsung pada user-defined async func (tanpa spawn)
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 1. await langsung (tanpa spawn) --")

async func sapa(nama):
    return "Halo, " + nama + "!"

async func kuadrat(n):
    return n * n

async func faktorial(n):
    if n <= 1:
        return 1
    sisa = await faktorial(n - 1)
    return n * sisa

# await bisa dipakai langsung di top-level script
let r1 = await sapa("Flux")
if r1 == "Halo, Flux!":
    lulus("await sapa()")
else:
    gagal("await sapa()", f"dapat: {r1}")

let r2 = await kuadrat(9)
if r2 == 81:
    lulus("await kuadrat(9) == 81")
else:
    gagal("await kuadrat(9)", f"dapat: {r2}")

let r3 = await faktorial(6)
if r3 == 720:
    lulus("await faktorial(6) == 720")
else:
    gagal("await faktorial(6)", f"dapat: {r3}")

# ─────────────────────────────────────────────────────────────────────────────
# 2. Rantai await: async memanggil async
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 2. Rantai await (async → async) --")

async func pitagoras(a, b):
    a2 = await kuadrat(a)
    b2 = await kuadrat(b)
    return a2 + b2

async func bagi(a, b):
    return a / b

async func pipeline(n):
    k = await kuadrat(n)         # n^2
    p = await pitagoras(3, 4)    # 25
    r = await bagi(k, p)         # n^2 / 25
    return r

let p = await pitagoras(3, 4)
if p == 25:
    lulus("pitagoras(3, 4) == 25")
else:
    gagal("pitagoras(3, 4)", f"dapat: {p}")

let pl = await pipeline(10)
if pl == 4.0:
    lulus("pipeline(10) == 4.0  (100 / 25)")
else:
    gagal("pipeline(10)", f"dapat: {pl}")

# ─────────────────────────────────────────────────────────────────────────────
# 3. spawn + await handle — concurrency eksplisit
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 3. spawn + await handle --")

let urutan = []

async func tugas(nama, tunda):
    await aio.sleep(tunda)
    urutan.append(nama)
    return nama

# B (30ms) harus selesai lebih dulu dari A (120ms) dan C (70ms)
let hA = spawn tugas("A", 120)
let hB = spawn tugas("B", 30)
let hC = spawn tugas("C", 70)

let rA = await hA
let rB = await hB
let rC = await hC

if rA == "A" and rB == "B" and rC == "C":
    lulus("nilai return dari spawn + await benar")
else:
    gagal("nilai return spawn+await", f"rA={rA} rB={rB} rC={rC}")

if urutan[0] == "B" and urutan[1] == "C" and urutan[2] == "A":
    lulus("urutan selesai: B→C→A (concurrency nyata)")
else:
    gagal("urutan selesai", f"dapat: {urutan}")

# ─────────────────────────────────────────────────────────────────────────────
# 4. Auto-spawn: memanggil async func tanpa await → handle coroutine
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 4. Auto-spawn (panggil tanpa await) --")

async func kerja(n):
    await aio.sleep(10)
    return n * 10

# Memanggil async func tanpa await → otomatis menjadi coroutine (auto-spawn)
# Hasilnya adalah handle coroutine, bukan nilai return fungsinya
let h1 = kerja(3)    # auto-spawn → handle
let h2 = kerja(7)    # auto-spawn → handle

let v1 = await h1    # sekarang tunggu hasilnya
let v2 = await h2

if v1 == 30 and v2 == 70:
    lulus("auto-spawn: kerja(3)=30, kerja(7)=70")
else:
    gagal("auto-spawn", f"v1={v1} v2={v2}")

# ─────────────────────────────────────────────────────────────────────────────
# 5. yield — cooperative multitasking tanpa I/O
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 5. yield (cooperative multitasking) --")

let log_yield = []

async func counter(nama, langkah):
    i = 0
    while i < langkah:
        log_yield.append(nama)
        yield        # serahkan giliran ke coroutine lain
        i = i + 1
    return nama + "_selesai"

let tX = spawn counter("X", 3)
let tY = spawn counter("Y", 3)

let rX = await tX
let rY = await tY

# yield menyebabkan X dan Y bergantian: X,Y,X,Y,X,Y
if rX == "X_selesai" and rY == "Y_selesai":
    lulus("yield: nilai return coroutine benar")
else:
    gagal("yield return", f"rX={rX} rY={rY}")

# Cek interleaving: tidak boleh semua X dulu baru semua Y
let ada_interleaving = false
let k = 0
while k < 5:
    if log_yield[k] != log_yield[k + 1]:
        ada_interleaving = true
    k = k + 1

if ada_interleaving:
    lulus("yield: coroutine saling bergantian (interleaving)")
else:
    gagal("yield interleaving", f"log: {log_yield}")

# ─────────────────────────────────────────────────────────────────────────────
# 6. aio.sleep — non-blocking, urutan selesai sesuai delay
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 6. aio.sleep --")

async func tidur(label, ms):
    await aio.sleep(ms)
    return label

# Sleep 0ms — yield ke scheduler, langsung kembali
let s0 = await tidur("zero", 0)
if s0 == "zero":
    lulus("aio.sleep(0) berjalan dan kembali")
else:
    gagal("aio.sleep(0)", f"dapat: {s0}")

# Dua sleep bersamaan: yang lebih pendek selesai duluan
let ha = spawn tidur("lambat", 100)
let hb = spawn tidur("cepat",  20)
let ra = await ha
let rb = await hb

if ra == "lambat" and rb == "cepat":
    lulus("aio.sleep: dua task bersamaan, nilai return benar")
else:
    gagal("aio.sleep dua task", f"ra={ra} rb={rb}")

# ─────────────────────────────────────────────────────────────────────────────
# 7. aio.read_file + aio.write_file
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 7. aio.write_file + aio.read_file --")

let path_tmp = "/tmp/flux_test_async_io.txt"
let isi_tulis = "Flux async I/O bekerja!\nBaris kedua.\n"

async func uji_io(path, isi):
    await aio.write_file(path, isi)
    let balik = await aio.read_file(path)
    return balik

let io_hasil = await uji_io(path_tmp, isi_tulis)

if io_hasil == isi_tulis:
    lulus("aio.write_file + aio.read_file roundtrip")
else:
    gagal("aio I/O roundtrip", f"dapat: {io_hasil}")

# ─────────────────────────────────────────────────────────────────────────────
# 8. aio.gather([...]) — fan-out bersamaan, hasil urut sesuai input
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 8. aio.gather([...]) --")

async func hitung_tunda(n, tunda):
    await aio.sleep(tunda)
    return n * n

# Delay berbeda — urutan hasil harus sesuai urutan input (bukan urutan selesai)
# delay: 4→10ms, 2→50ms, 3→20ms  (selesai: 4,3,2; hasil harus [16,4,9])
let g_hasil = await aio.gather([hitung_tunda(4, 10), hitung_tunda(2, 50), hitung_tunda(3, 20)])

if g_hasil[0] == 16 and g_hasil[1] == 4 and g_hasil[2] == 9:
    lulus("aio.gather: hasil [16,4,9] urut sesuai input")
else:
    gagal("aio.gather urutan hasil", f"dapat: {g_hasil}")

# ─────────────────────────────────────────────────────────────────────────────
# 9. aio.create_task(coro)
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 9. aio.create_task(coro) --")

async func kalikan(n):
    await aio.sleep(10)
    return n * 5

# create_task menerima coroutine handle (auto-spawn) dan mengembalikannya
let ct_a = aio.create_task(kalikan(4))
let ct_b = aio.create_task(kalikan(9))

let ct_ra = await ct_a
let ct_rb = await ct_b

if ct_ra == 20 and ct_rb == 45:
    lulus("aio.create_task: kalikan(4)=20, kalikan(9)=45")
else:
    gagal("aio.create_task", f"ct_ra={ct_ra} ct_rb={ct_rb}")

# ─────────────────────────────────────────────────────────────────────────────
# 10. Fan-out / fan-in manual: spawn banyak, await satu per satu
# ─────────────────────────────────────────────────────────────────────────────
print("\n-- 10. Fan-out / fan-in manual --")

async func proses(id, tunda):
    await aio.sleep(tunda)
    return id * id

# Semua task berjalan bersamaan (fan-out), lalu dikumpulkan (fan-in)
let handles = []
let fi = 1
while fi <= 6:
    handles.append(spawn proses(fi, 40))
    fi = fi + 1

let fo_hasil = []
fi = 0
while fi < 6:
    fo_hasil.append(await handles[fi])
    fi = fi + 1

if fo_hasil[0] == 1 and fo_hasil[1] == 4 and fo_hasil[2] == 9 and fo_hasil[3] == 16 and fo_hasil[4] == 25 and fo_hasil[5] == 36:
    lulus("fan-out/fan-in: [1,4,9,16,25,36]")
else:
    gagal("fan-out/fan-in", f"dapat: {fo_hasil}")

# ─────────────────────────────────────────────────────────────────────────────
# Ringkasan
# ─────────────────────────────────────────────────────────────────────────────
print(f"\n=== {hasil[0]} lulus, {hasil[1]} gagal ===")
