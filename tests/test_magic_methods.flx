# Test all Flux magic methods

print("=== Testing Magic Methods ===")
print("")

# ── init (constructor) ────────────────────────────────────────────────
print("--- init ---")
class Point:
    func __init__(x, y):
        self.x = x
        self.y = y

p = Point(3, 4)
print(p.x)   # 3
print(p.y)   # 4

# ── to_str (print / str) ──────────────────────────────────────────────
print("--- to_str ---")
class Vec2:
    func __init__(x, y):
        self.x = x
        self.y = y
    func to_str():
        return "Vec2(" + str(self.x) + ", " + str(self.y) + ")"

v = Vec2(1, 2)
print(v)         # Vec2(1, 2)
print(str(v))    # Vec2(1, 2)

# ── to_repr (debug representation) ────────────────────────────────────
print("--- to_repr ---")
class Color:
    func __init__(r, g, b):
        self.r = r
        self.g = g
        self.b = b
    func to_repr():
        return "Color(r=" + str(self.r) + ", g=" + str(self.g) + ", b=" + str(self.b) + ")"
    func to_str():
        return "rgb(" + str(self.r) + ", " + str(self.g) + ", " + str(self.b) + ")"

c = Color(255, 128, 0)
print(repr(c))   # Color(r=255, g=128, b=0)
print(c)         # rgb(255, 128, 0)

# ── on_len (len() support) ────────────────────────────────────────────
print("--- on_len ---")
class Stack:
    func __init__():
        self.items = []
    func push(val):
        self.items.append(val)
    func on_len():
        return len(self.items)

s = Stack()
s.push(10)
s.push(20)
s.push(30)
print(len(s))   # 3

# ── on_get / on_set (indexing) ────────────────────────────────────────
print("--- on_get / on_set ---")
class SparseArray:
    func __init__():
        self.data = {}
    func on_get(key):
        k = str(key)
        if self.data.has_key(k):
            return self.data[k]
        return 0
    func on_set(key, val):
        self.data[str(key)] = val

a = SparseArray()
a[5] = 42
a[10] = 99
print(a[5])    # 42
print(a[10])   # 99
print(a[0])    # 0  (default)

# ── on_iter (for-loop support) ────────────────────────────────────────
print("--- on_iter ---")
class Range2:
    func __init__(start, stop):
        self.start = start
        self.stop  = stop
    func on_iter():
        result = []
        i = self.start
        while i < self.stop:
            result.append(i)
            i = i + 1
        return result

for x in Range2(3, 7):
    print(x)   # 3 4 5 6

# ── on_len + on_get for-loop (direct iteration via protocol) ──────────
print("--- on_len + on_get for-loop ---")
class NumberedList:
    func __init__():
        self.items = ["a", "b", "c"]
    func on_len():
        return len(self.items)
    func on_get(i):
        return self.items[i]

nl = NumberedList()
for item in nl:
    print(item)   # a b c

# ── on_call (callable instances) ─────────────────────────────────────
print("--- on_call ---")
class Multiplier:
    func __init__(factor):
        self.factor = factor
    func on_call(x):
        return x * self.factor

double = Multiplier(2)
triple = Multiplier(3)
print(double(7))   # 14
print(triple(5))   # 15

# ── __enter__ / __exit__ (with statement) ────────────────────────────
print("--- __enter__ / __exit__ ---")
class Timer:
    func __init__(name):
        self.name = name
    func __enter__():
        print("Entering: " + self.name)
        return self
    func __exit__():
        print("Exiting: " + self.name)

with Timer("block1"):
    print("inside block")

with Timer("block2") as t:
    print("inside block with handle: " + t.name)

print("")
print("=== All tests passed ===")
