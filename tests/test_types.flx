# Test: type() function and type coercions
print("=== Types ===")
print(type(1))
print(type(3.14))
print(type("hello"))
print(type(true))
print(type(null))
print(type([]))
print(type({}))

# Conversions
print(int("42"))
print(float("3.14"))
print(str(100))
print(int(3.9))
print(float(5))

# Bad conversion — harus error, bukan crash
print("Bad int conversion:")
try:
    print(int("abc"))
catch e:
    print("[PASS] konversi buruk tertangkap: " + str(e))

print("types: OK")
