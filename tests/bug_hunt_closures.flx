# Bug Hunt: Closures and upvalues
print("=== CLOSURES ===")

# Basic closure
func make_counter():
    count = 0
    func increment():
        count = count + 1
        return count
    return increment

c1 = make_counter()
c2 = make_counter()
print(c1())  # 1
print(c1())  # 2
print(c1())  # 3
print(c2())  # 1  (independent)
print(c2())  # 2

# Closure captures variable, not value
func make_adder(n):
    func add(x):
        return x + n
    return add

add5 = make_adder(5)
add10 = make_adder(10)
print(add5(3))   # 8
print(add10(3))  # 13

# Nested closures (closure of closure)
func outer():
    x = 1
    func middle():
        y = 2
        func inner():
            return x + y
        return inner
    return middle

f = outer()()
print(f())   # 3

# Closure in loop - common bug: should capture different values
funcs = []
for i in range(5):
    func make_fn(val):
        func fn():
            return val
        return fn
    funcs.append(make_fn(i))

print(funcs[0]())   # 0
print(funcs[1]())   # 1
print(funcs[2]())   # 2
print(funcs[3]())   # 3
print(funcs[4]())   # 4

# Mutual recursion via closures
func make_pair():
    func is_even(n):
        if n == 0:
            return true
        return is_odd(n - 1)
    func is_odd(n):
        if n == 0:
            return false
        return is_even(n - 1)
    return [is_even, is_odd]

# pair = make_pair()
# print(pair[0](4))   # true (is_even)
# print(pair[1](3))   # true (is_odd)

# Closure modifying upvalue via helper
func make_accumulator():
    total = 0
    func add(n):
        total = total + n
        return total
    return add

acc = make_accumulator()
print(acc(10))   # 10
print(acc(20))   # 30
print(acc(5))    # 35

print("CLOSURE TESTS DONE")
